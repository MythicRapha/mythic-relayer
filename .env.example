# Network
L1_RPC_URL=https://api.devnet.solana.com
L2_RPC_URL=http://localhost:8899
NETWORK=devnet

# Programs
L1_BRIDGE_PROGRAM=oEQfREm4FQkaVeRoxJHkJLB1feHprrntY6eJuW2zbqQ
L2_BRIDGE_PROGRAM=3HsETxbcFZ5DnGiLWy3fEvpwQFzb2ThqLXY1eWQjjMLS
MYTH_TOKEN_MINT=7Hmyi9v4itEt49xo1fpTgHk1ytb8MZft7RBATBgb1pnf

# Relayer keypair (path to keypair JSON file)
RELAYER_KEYPAIR_PATH=./keys/relayer.json

# Database
DB_PATH=./data/relayer.db

# Timing
POLL_INTERVAL_MS=5000
CHALLENGE_PERIOD_SECONDS=604800

# Logging
LOG_LEVEL=info

# Migration System (L1 DEX -> L2 auto-migration)
MIGRATION_ENABLED=true
MIGRATION_MIN_LIQUIDITY_SOL=1.0
MIGRATION_AUTO=true
MIGRATION_POLL_MS=15000
MIGRATION_BLACKLIST=
MIGRATION_WHITELIST=
L2_SWAP_PROGRAM=MythSwap11111111111111111111111111111111111
