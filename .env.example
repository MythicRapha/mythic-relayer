# Network
L1_RPC_URL=https://api.devnet.solana.com
L2_RPC_URL=http://MYTHIC_SERVER_IP:8899
NETWORK=devnet

# Programs
L1_BRIDGE_PROGRAM=MythBrdg11111111111111111111111111111111111
L2_BRIDGE_PROGRAM=MythBrdgL2111111111111111111111111111111111
MYTH_TOKEN_MINT=MythToken1111111111111111111111111111111111

# Relayer keypair (path to keypair JSON file)
RELAYER_KEYPAIR_PATH=/mnt/data/mythic-l2/keys/relayer.json

# Database
DB_PATH=./data/relayer.db

# Timing
POLL_INTERVAL_MS=5000
CHALLENGE_PERIOD_SECONDS=604800

# Logging
LOG_LEVEL=info
